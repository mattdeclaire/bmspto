---
import PageLayout from "@layouts/PageLayout.astro";

const photos = [
    "IMG_4692",
    "IMG_4958",
    "IMG_4816",
    "IMG_4913-2",
    "IMG_4939",
    "IMG_4748-2",
];
---

<PageLayout title="Viking Night">
    <div class="panel panel-gold">
        <p class="text-lg">BMS Viking night will be held Friday, October 9th, from 5 - 8pm on the BMS campus. The event will feature food trucks, inflatable obstacle courses, a teacher-led auction, and an art gallery featuring student art.</p>
        <p><strong>We need your support.</strong> Viking Night is not possible without the help of volunteers. Whether you can spare an hour or stay the whole evening, your time and energy will make a big difference. Sign up to help.</p>
        <p><a href="https://forms.gle/NrjJbVHhr2y3R5qV9" class="btn">Viking Night Volunteer Form</a></p>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-3 md:gap-4">
        {photos.map(photo => (
            <img
                src={`/img/viking-night/${photo}.jpg`}
                alt="Having fun at Viking Night 2024"
                class="aspect-4/3 w-full rounded-xl object-cover shadow-sm"
                loading="lazy"
            />
        ))}
    </div>
</PageLayout>
